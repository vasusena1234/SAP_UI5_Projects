<mvc:View controllerName="com.te.myportfolio.controller.Main" displayBlock="true" core:require="{
		formatter: 'com/te/myportfolio/model/formatter'
	}"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.uxap"
    xmlns:m="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:u="sap.ui.unified"
    xmlns:forms="sap.ui.layout.form" height="100%">
    <ObjectPageLayout id="ObjectPageLayout" upperCaseAnchorBar="false">
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
                <expandedHeading>
                    <m:Title text="{portfolio>/name}" />
                </expandedHeading>

                <snappedHeading>
                    <m:HBox>
                        <m:Avatar src="https://avatars.githubusercontent.com/u/59472341?v=4" class="sapUiMediumMarginEnd" displayShape="Square" />
                        <m:VBox>
                            <m:Title text="{portfolio>/name}" />
                            <m:Label text="{portfolio>/designation}" />
                        </m:VBox>
                    </m:HBox>
                </snappedHeading>

                <expandedContent>
                    <m:Label text="{portfolio>/designation}" />
                </expandedContent>

                <snappedTitleOnMobile>
                    <m:Title text="{portfolio>/name}" />
                </snappedTitleOnMobile>

                <actions>
                    <m:Button text="Hire Me" type="Emphasized" />
                    <m:Button text="Refer Me" />
                    <m:Button text="Contact Me" icon="sap-icon://call" />
                </actions>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

        <headerContent>
            <m:FlexBox wrap="Wrap" fitContainer="true">
                <m:Avatar src="https://avatars.githubusercontent.com/u/59472341?v=4" class="sapUiMediumMarginEnd" displayShape="Square" displaySize="L" />

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:HBox class="sapUiTinyMarginBottom" renderType="Bare">
                        <m:Label text="First Name" class="sapUiTinyMarginEnd" />
                        <m:Text text="{portfolio>/firstName}" />
                    </m:HBox>

                    <m:HBox class="sapUiTinyMarginBottom" renderType="Bare">
                        <m:Label text="{portfolio>/lastName}" class="sapUiTinyMarginEnd" />
                        <m:Text text=" Gunda" />
                    </m:HBox>

                    <m:HBox>
                        <m:Label text="Place" class="sapUiTinyMarginEnd" />
                        <m:Text text="Hyderabad India" />
                    </m:HBox>
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:Title text="Status" class="sapUiTinyMarginBottom" />
                    <m:ObjectStatus text="Open to Work" state="Success" class="sapMObjectStatusLarge" />
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:Title text="Mail" class="sapUiTinyMarginBottom" />
                    <m:ObjectStatus text="{portfolio>/email}" state="Warning" class="sapMObjectStatusLarge" />
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:Title text="Current Company" class="sapUiTinyMarginBottom" />
                    <m:ObjectStatus text="{portfolio>/currentCompany}" state="Information" class="sapMObjectStatusLarge" />
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:Title text="Notice Period" class="sapUiTinyMarginBottom" />
                    <m:ObjectStatus text="90 days" icon="sap-icon://calendar" class="sapMObjectStatusLarge" />
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom">
                    <m:Title text="Phone" class="sapUiTinyMarginBottom" />
                    <m:ObjectStatus text="{portfolio>/phone}" state="Error" class="sapMObjectStatusLarge" />
                </m:VBox>

                <m:VBox class="sapUiLargeMarginEnd">
                    <m:Title text="Monthly Expected Salary" class="sapUiTinyMarginBottom" />
                    <m:ObjectNumber number="1,49,999.99" unit="INR" emphasized="true" class="sapMObjectNumberLarge" />
                </m:VBox>
            </m:FlexBox>
        </headerContent>

        <sections>
            <ObjectPageSection titleUppercase="false" title="Education">
                <subSections>
                    <ObjectPageSubSection title="Education">
                        <blocks>
                            <m:Table class="sapUxAPObjectPageSubSectionAlignContent" width="auto" items = "{portfolio>/education}">

                                <m:columns>
                                    <m:Column>
                                        <m:Text text="College" />
                                    </m:Column>
                                    <m:Column minScreenWidth="Tablet" demandPopin="true">
                                        <m:Text text="Year" />
                                    </m:Column>
                                    <m:Column minScreenWidth="Tablet" demandPopin="true">
                                        <m:Text text="Type" />
                                    </m:Column>
                                    <m:Column minScreenWidth="Tablet" demandPopin="true">
                                        <m:Text text="Percent" />
                                    </m:Column>

                                </m:columns>

                                <m:items>
                                    <m:ColumnListItem>
                                        <m:Text text="{portfolio>college}" />
                                        <m:Text text="{portfolio>year}" />
                                        <m:Text text="{portfolio>type}" />
                                        <m:Text text="{portfolio>percent}" />
                                    </m:ColumnListItem>

                                </m:items>
                            </m:Table>
                        </blocks>
                    </ObjectPageSubSection>

                </subSections>
            </ObjectPageSection>


            <ObjectPageSection titleUppercase="false" title="Certificatios">
                <subSections>
                    <ObjectPageSubSection title="Certificatios">
                        <blocks>
                            <m:FlexBox height="200px" alignItems="Center" justifyContent="Center" items = "{portfolio>/certification}">



                                <m:GenericTile class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{portfolio>name}" mode="HeaderMode" press=".press">
                                    <m:TileContent footer="{portfolio>year}" footerColor = "Good"/>
                                </m:GenericTile>

                            </m:FlexBox>
                        </blocks>
                    </ObjectPageSubSection>

                </subSections>
            </ObjectPageSection>


            <ObjectPageSection titleUppercase="false" title="Employment">
                <subSections>
                    <ObjectPageSubSection title="Employment">
                        <blocks>
                            <t:TreeTable id="TreeTableBasic" rows="{path:'portfolio>/employment', parameters: {arrayNames:['projects']}}" selectionMode="MultiToggle" enableSelectAll="false" ariaLabelledBy="title">

                                <t:columns>
                                    <t:Column width="13rem">
                                        <m:Label text="Name"/>
                                        <t:template>
                                            <m:Text text="{portfolio>name}" wrapping="false" />
                                        </t:template>
                                    </t:Column>
                                    <t:Column width="13rem">
                                        <m:Label text="Client"/>
                                        <t:template>
                                            <m:Text text="{portfolio>client}" wrapping="false" />
                                        </t:template>
                                    </t:Column>


                                </t:columns>
                            </t:TreeTable>
                        </blocks>
                    </ObjectPageSubSection>
                </subSections>
            </ObjectPageSection>
        </sections>
    </ObjectPageLayout>
</mvc:View>
