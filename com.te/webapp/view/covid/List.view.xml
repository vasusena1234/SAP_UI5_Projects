<mvc:View
    controllerName="com.te.controller.covid.List"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
>
    <Shell>
        <Page
            id="list"
            showHeader="false"
        >
            <List
            
                id="myList"
                headerText="Total cases across nation: {Latest>/data/summary/total}"
                items="{Latest>/data/regional}"
            >
                <items>
                    <StandardListItem
                        title="{Latest>loc}"
                        description="Total cases: {Latest>totalConfirmed}"
                        info="Deaths: {Latest>deaths}"
                        infoState="Error"
                    />
                </items>
            </List>
        </Page>
    </Shell>
</mvc:View>
